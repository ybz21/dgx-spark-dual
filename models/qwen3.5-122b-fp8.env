# =============================================================================
# Qwen3.5-122B-A10B FP8 — TP2 Multi-Node
# =============================================================================

# ---- Image ----
VLLM_IMAGE=vllm-spark:v018-ngc2603-staging

# ---- Model ----
MODEL_PATH=[model_path]/Qwen_Qwen3.5-122B-A10B-FP8
MODEL_CONTAINER_PATH=/models/Qwen3.5-122B-A10B-FP8
SERVED_MODEL_NAME=Qwen/Qwen3.5-122B-A10B-FP8

# ---- Cluster ----
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=65536
MAX_NUM_SEQS=4
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_BATCHED_TOKENS=32768

# ---- Extra args ----
VLLM_EXTRA_ARGS=--enable-chunked-prefill --reasoning-parser qwen3

# ---- Model-specific env vars ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_NVFP4_MOE_FORCE_MARLIN=0

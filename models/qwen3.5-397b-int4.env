# =============================================================================
# Qwen3.5-397B-A17B INT4 (AutoRound) — TP2 Multi-Node
# Currently in production on spark01 (head) + spark02 (worker)
# =============================================================================

# ---- Image ----
VLLM_IMAGE=vllm-spark:v018-ngc2603-staging

# ---- Model ----
MODEL_PATH=[model_path]/Intel_Qwen3.5-397B-A17B-int4-AutoRound
MODEL_CONTAINER_PATH=/models/Qwen3.5-397B-A17B-int4-AutoRound
SERVED_MODEL_NAME=Qwen/Qwen3.5-397B-A17B-int4-AutoRound

# ---- Cluster ----
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=8
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_BATCHED_TOKENS=16384

# ---- Extra args ----
VLLM_EXTRA_ARGS=--kv-cache-dtype fp8 --reasoning-parser qwen3 --enable-auto-tool-choice --tool-call-parser qwen3_coder

# ---- Model-specific env vars ----
VLLM_MARLIN_USE_ATOMIC_ADD=1
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_NVFP4_MOE_FORCE_MARLIN=0
